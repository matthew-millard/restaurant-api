<h1>Order Confirmed!</h1>

<p>Hi <%= @order.customer_name %>,</p>

<p>Your order <strong>#<%= @order.id[0..7] %></strong> has been placed.</p>

<h2>Order Summary</h2>

<table style="border-collapse: collapse; width: 100%;">
  <tr style="border-bottom: 2px solid #333;">
    <th style="text-align: left; padding: 8px;">Item</th>
    <th style="text-align: center; padding: 8px;">Qty</th>
    <th style="text-align: right; padding: 8px;">Price</th>
  </tr>
  <% @order_items.each do |oi| %>
    <tr style="border-bottom: 1px solid #ddd;">
      <td style="padding: 8px;">
        <%= oi.menu_item&.name %>
        <% if oi.modifications.present? %>
          <br><small style="color: #666;"><%= oi.modifications %></small>
        <% end %>
      </td>
      <td style="text-align: center; padding: 8px;"><%= oi.quantity %></td>
      <td style="text-align: right; padding: 8px;">$<%= "%.2f" % ((oi.unit_price_cents || 0) * (oi.quantity || 0) / 100.0) %></td>
    </tr>
  <% end %>
  <tr>
    <td colspan="2" style="text-align: right; padding: 8px;"><strong>Total</strong></td>
    <td style="text-align: right; padding: 8px;"><strong>$<%= "%.2f" % ((@order.total_cents || 0) / 100.0) %></strong></td>
  </tr>
</table>

<p><strong>Pickup time:</strong> <%= @order.pickup_time %></p>

<p>If you need to cancel, please do so before your order is prepared.</p>

<p>Thank you!</p>
